<svg xmlns="http://www.w3.org/2000/svg" width="800" height="800">
  <filter id="marble">
    <feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="4" result="noise" />
    <feColorMatrix type="matrix" values="1 0 0 0 0  0 0.95 0 0 0  0 0.85 0 0 0  0 0 0 0.25 0" in="noise" result="coloredNoise" />
    <feComposite operator="in" in="coloredNoise" in2="SourceGraphic" />
  </filter>
  <rect width="100%" height="100%" fill="#fff" filter="url(#marble)" opacity="0.1"/>
</svg>
